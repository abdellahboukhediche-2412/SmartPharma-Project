<Window x:Class="SmartPharma.Views.MedicamentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des médicaments"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Text="Gestion des médicaments"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Barre d'actions -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,15">

            <TextBox x:Name="txtRecherche"
                     Width="250"
                     Height="30"
                     Margin="0,0,10,0"/>

            <Button Content="Rechercher"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="BtnRechercher_Click"/>

            <Button Content="Tout afficher"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="BtnToutAfficher_Click"/>

            <Button Content="Ajouter"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="BtnAjouter_Click"/>

            <Button Content="Modifier"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="BtnModifier_Click"/>

            <Button Content="Supprimer"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="BtnSupprimer_Click"/>

        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="dgMedicaments"
                  Grid.Row="2"
                  AutoGenerateColumns="True"
                  Margin="0,0,0,10"/>

        <!-- Bouton Retour -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="← Retour"
                    Width="120"
                    Height="35"
                    Click="BtnRetour_Click"/>

        </StackPanel>

    </Grid>

</Window>
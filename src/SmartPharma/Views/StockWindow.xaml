<Window x:Class="SmartPharma.Views.StockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion du stock"
        Height="620"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#0B3D3E"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Gestion du stock"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Consulter les quantités disponibles et détecter les stocks faibles"
                           FontSize="15"
                           Foreground="#DDEFEA"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,20">

            <DockPanel>
                <TextBox x:Name="txtRecherche"
                         Width="280"
                         Height="36"
                         Padding="10,0"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>

                <Button Content="Rechercher"
                        Width="110"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#3498DB"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnRechercher_Click"/>

                <Button Content="Tout afficher"
                        Width="115"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#7F8C8D"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnToutAfficher_Click"/>

                <Button Content="Stock faible"
                        Width="110"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#E67E22"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnStockFaible_Click"/>

                <Button Content="Modifier quantité"
                        Width="150"
                        Height="36"
                        Background="#2ECC71"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnModifierQuantite_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="10"
                Margin="0,0,0,20">

            <DataGrid x:Name="dgStock"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      RowHeight="35"
                      FontSize="14"
                      GridLinesVisibility="None"
                      AlternatingRowBackground="#F2F6F5"
                      Background="White"
                      BorderThickness="0">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="60"/>

                    <DataGridTextColumn Header="Nom du médicament"
                                        Binding="{Binding Nom}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Prix"
                                        Binding="{Binding Prix}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Quantité"
                                        Binding="{Binding QuantiteStock}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Date d'expiration"
                                        Binding="{Binding DateExpiration}"
                                        Width="180"/>

                    <DataGridTextColumn Header="État du stock"
                                        Binding="{Binding EtatStock}"
                                        Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="3">
            <TextBlock Text="SmartPharma - Module stock"
                       Foreground="#0B3D3E"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Content="← Retour"
                    Width="130"
                    Height="38"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Background="#0B3D3E"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="BtnRetour_Click"/>
        </DockPanel>
    </Grid>
</Window>
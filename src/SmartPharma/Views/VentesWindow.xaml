<Window x:Class="SmartPharma.Views.VentesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des ventes"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F6">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== HEADER ===================== -->

        <Border Background="#0B3D3E"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">

            <StackPanel>

                <TextBlock Text="Gestion des ventes"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Enregistrer les ventes et mettre automatiquement le stock à jour"
                           FontSize="15"
                           Foreground="#DDEFEA"
                           Margin="0,5,0,0"/>

            </StackPanel>

        </Border>

        <!-- ===================== SAISIE ===================== -->

        <Border Grid.Row="1"
        Background="White"
        CornerRadius="12"
        Padding="20"
        Margin="0,0,0,20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Médicament" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbMedicaments"
                      Height="35"
                      Margin="0,5,10,0"
                      DisplayMemberPath="Nom"
                      SelectedValuePath="Id"
                      SelectionChanged="cmbMedicaments_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Prix" FontWeight="Bold"/>
                    <TextBox x:Name="txtPrix"
                     Height="35"
                     Margin="0,5,10,0"
                     IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Stock" FontWeight="Bold"/>
                    <TextBox x:Name="txtStock"
                     Height="35"
                     Margin="0,5,10,0"
                     IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Date expiration" FontWeight="Bold"/>
                    <TextBox x:Name="txtExpiration"
                     Height="35"
                     Margin="0,5,10,0"
                     IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Quantité" FontWeight="Bold"/>
                    <TextBox x:Name="txtQuantite"
                     Height="35"
                     Margin="0,5,10,0"/>
                </StackPanel>

                <Button Grid.Column="5"
                Margin="10,22,10,0"
                Height="35"
                Background="#3498DB"
                Foreground="White"
                FontWeight="Bold"
                Content="Calculer"
                Click="BtnCalculer_Click"/>

                <Button Grid.Column="6"
                Margin="10,22,0,0"
                Height="35"
                Background="#2ECC71"
                Foreground="White"
                FontWeight="Bold"
                Content="Enregistrer"
                Click="BtnEnregistrerVente_Click"/>
            </Grid>
        </Border>

        <!-- ===================== TOTAL ===================== -->

        <Border Grid.Row="2"
        Background="#0B3D3E"
        CornerRadius="12"
        Padding="20"
        Margin="0,0,0,20">

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="💰 Montant total : "
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"/>

                <TextBlock x:Name="txtTotal"
                   Text="0,00 $"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#2ECC71"/>

            </StackPanel>

        </Border>

        <!-- ===================== TABLEAU ===================== -->

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="10"
                Margin="0,0,0,20">

            <DataGrid x:Name="dgVentes"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      AlternatingRowBackground="#F2F6F5"
                      HeadersVisibility="Column"
                      RowHeight="35"
                      FontSize="14"
                      GridLinesVisibility="None"
                      BorderThickness="0"/>

        </Border>

        <!-- ===================== FOOTER ===================== -->

        <DockPanel Grid.Row="4">

            <TextBlock Text="SmartPharma - Module ventes"
                       FontWeight="Bold"
                       Foreground="#0B3D3E"
                       VerticalAlignment="Center"/>

            <Button Content="← Retour"
                    Width="130"
                    Height="40"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Background="#0B3D3E"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="BtnRetour_Click"/>

        </DockPanel>

    </Grid>

</Window>
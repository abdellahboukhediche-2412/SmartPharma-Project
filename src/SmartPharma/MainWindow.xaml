<Window x:Class="SmartPharma.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartPharma"
        Height="400"
        Width="600">

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="SmartPharma"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <Button Content="Gestion des médicaments"
                    Height="45"
                    Margin="0,0,0,15"
                    Click="BtnMedicaments_Click"/>

            <Button Content="Gestion du stock"
                    Height="45"
                    Margin="0,0,0,15"
                    Click="BtnStock_Click"/>

            <Button Content="Gestion des ventes"
                    Height="45"
                    Click="BtnVentes_Click"/>

        </StackPanel>
    </Grid>
</Window>